{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "types": ["@motrix/plugin-api"],
    "lib": ["ES2020", "DOM"]
  },
  "include": ["src"],
  "exclude": ["**/*.test.ts"]
}
